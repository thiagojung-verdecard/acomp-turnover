# Public environment variables (exposed to browser)
NEXT_PUBLIC_APP_NAME=Dashboard
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Private environment variables (server-only)
# These are never exposed to the browser
PRIVATE_DATABASE_URL=postgresql://user:password@localhost:5432/dashboard_db

# Python pool service configuration
POOL_RUNTIME=Linux
POOL_HOST=172.22.1.202
POOL_PORT=8080
TURNOVER_ALLOW_MOCK_FALLBACK=true

